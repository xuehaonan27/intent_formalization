{
  "function": "alloc",
  "det_check_template": "proof fn det_alloc(pre_self_: Bitmap, post1_self_: Bitmap, r1: Result<usize, Error>, post2_self_: Bitmap, r2: Result<usize, Error>)\n    requires pre_self_.inv(),\n    ensures\n        (post1_self_.inv()\n        && match r1 {\n                Ok(index_1) => {\n                    &&& 0 <= index_1 < post1_self_@.num_bits\n                    &&& post1_self_@.num_bits == pre_self_@.num_bits\n                    &&& !pre_self_@.is_bit_set(index_1 as int)\n                    &&& post1_self_@.is_bit_set(index_1 as int)\n                    &&& forall|i: int|\n                        0 <= i < post1_self_@.num_bits && i != index_1 ==> post1_self_@.is_bit_set(i) == pre_self_@.is_bit_set(i)\n                    &&& post1_self_@.set_bits == pre_self_@.set_bits.insert(index_1 as int)\n                    &&& post1_self_@.usage() == pre_self_@.usage() + 1\n                },\n                Err(_) => {\n                    &&& pre_self_@.is_full()\n                    &&& post1_self_@ == pre_self_@\n                },\n            }\n        && post2_self_.inv()\n        && match r2 {\n                Ok(index_2) => {\n                    &&& 0 <= index_2 < post2_self_@.num_bits\n                    &&& post2_self_@.num_bits == pre_self_@.num_bits\n                    &&& !pre_self_@.is_bit_set(index_2 as int)\n                    &&& post2_self_@.is_bit_set(index_2 as int)\n                    &&& forall|i: int|\n                        0 <= i < post2_self_@.num_bits && i != index_2 ==> post2_self_@.is_bit_set(i) == pre_self_@.is_bit_set(i)\n                    &&& post2_self_@.set_bits == pre_self_@.set_bits.insert(index_2 as int)\n                    &&& post2_self_@.usage() == pre_self_@.usage() + 1\n                },\n                Err(_) => {\n                    &&& pre_self_@.is_full()\n                    &&& post2_self_@ == pre_self_@\n                },\n            }\n        {ASSUMES})\n        ==> post1_self_@ == post2_self_@ && r1 == r2\n{\n}",
