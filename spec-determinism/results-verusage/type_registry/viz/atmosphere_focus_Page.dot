digraph "atmosphere_deps" {
  rankdir=BT;
  graph [bgcolor="white", fontname="Helvetica", fontsize=12, splines=true, overlap=false, nodesep=0.25, ranksep=0.6];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, margin="0.10,0.05"];
  edge [arrowsize=0.6, color="#90A4AE", penwidth=0.8];
  { rank=same; "ContainerPtr" "Cpu" "Endpoint" "Ghost" "IOid" "Node" "Option" "Page" "PagePtr" "PageState" "Pcid" "SLLIndex" "Set" "StaticLinkedList" "VAddr" }
  { rank=same; "Container" "PageAllocator" "Process" "Thread" }
  { rank=same; "ProcessManager" }
  { rank=same; "Kernel" }
  "Container" [label="Container\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "ContainerPtr" [label="ContainerPtr\n<alias>", fillcolor="#F3E5F5", color="#7B1FA2", penwidth=3.0];
  "Cpu" [label="Cpu\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "Endpoint" [label="Endpoint\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "Ghost" [label="Ghost\n<container>", fillcolor="#E8F5E9", color="#388E3C"];
  "IOid" [label="IOid\n<alias>", fillcolor="#F3E5F5", color="#7B1FA2"];
  "Kernel" [label="Kernel\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "Node" [label="Node\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "Option" [label="Option\n<container>", fillcolor="#E8F5E9", color="#388E3C"];
  "Page" [label="Page\n<struct>", fillcolor="#E3F2FD", color="#1976D2", penwidth=3.0];
  "PageAllocator" [label="PageAllocator\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "PagePtr" [label="PagePtr\n<alias>", fillcolor="#F3E5F5", color="#7B1FA2"];
  "PageState" [label="PageState\n<enum>", fillcolor="#FFF3E0", color="#F57C00"];
  "Pcid" [label="Pcid\n<alias>", fillcolor="#F3E5F5", color="#7B1FA2"];
  "Process" [label="Process\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "ProcessManager" [label="ProcessManager\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "SLLIndex" [label="SLLIndex\n<alias>", fillcolor="#F3E5F5", color="#7B1FA2", penwidth=3.0];
  "Set" [label="Set\n<container>", fillcolor="#E8F5E9", color="#388E3C"];
  "StaticLinkedList" [label="StaticLinkedList\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "Thread" [label="Thread\n<struct>", fillcolor="#E3F2FD", color="#1976D2"];
  "VAddr" [label="VAddr\n<alias>", fillcolor="#F3E5F5", color="#7B1FA2"];
  "Container" -> "ContainerPtr";
  "Container" -> "Ghost";
  "Container" -> "Option";
  "Container" -> "SLLIndex";
  "Container" -> "Set";
  "Container" -> "StaticLinkedList";
  "Cpu" -> "ContainerPtr";
  "Cpu" -> "Option";
  "Endpoint" -> "ContainerPtr";
  "Endpoint" -> "Ghost";
  "Endpoint" -> "Set";
  "Endpoint" -> "StaticLinkedList";
  "Kernel" -> "Ghost";
  "Kernel" -> "PageAllocator";
  "Kernel" -> "PagePtr";
  "Kernel" -> "ProcessManager";
  "Kernel" -> "Set";
  "Kernel" -> "VAddr";
  "Node" -> "Option";
  "Node" -> "SLLIndex";
  "Page" -> "ContainerPtr";
  "Page" -> "Ghost";
  "Page" -> "IOid";
  "Page" -> "Option";
  "Page" -> "PagePtr";
  "Page" -> "PageState";
  "Page" -> "Pcid";
  "Page" -> "SLLIndex";
  "Page" -> "Set";
  "Page" -> "VAddr";
  "PageAllocator" -> "ContainerPtr";
  "PageAllocator" -> "Ghost";
  "PageAllocator" -> "Page";
  "PageAllocator" -> "PagePtr";
  "PageAllocator" -> "Set";
  "PageAllocator" -> "StaticLinkedList";
  "Process" -> "ContainerPtr";
  "Process" -> "Ghost";
  "Process" -> "IOid";
  "Process" -> "Option";
  "Process" -> "Pcid";
  "Process" -> "SLLIndex";
  "Process" -> "Set";
  "Process" -> "StaticLinkedList";
  "ProcessManager" -> "Container";
  "ProcessManager" -> "ContainerPtr";
  "ProcessManager" -> "Cpu";
  "ProcessManager" -> "Endpoint";
  "ProcessManager" -> "Process";
  "ProcessManager" -> "Thread";
  "StaticLinkedList" -> "Ghost";
  "StaticLinkedList" -> "Node";
  "StaticLinkedList" -> "SLLIndex";
  "Thread" -> "ContainerPtr";
  "Thread" -> "Option";
  "Thread" -> "SLLIndex";
  subgraph cluster_legend {
    label="legend"; style="rounded"; color="#9E9E9E";
    fontcolor="#616161"; fontsize=10;
    node [shape=box, style="rounded,filled", fontsize=9, margin="0.06,0.03"];
    leg_struct [label="struct", fillcolor="#E3F2FD", color="#1976D2"];
    leg_enum [label="enum", fillcolor="#FFF3E0", color="#F57C00"];
    leg_alias [label="alias", fillcolor="#F3E5F5", color="#7B1FA2"];
    leg_union [label="union", fillcolor="#E0F7FA", color="#0097A7"];
    leg_container [label="container", fillcolor="#E8F5E9", color="#388E3C"];
    leg_primitive [label="primitive", fillcolor="#FAFAFA", color="#616161"];
    leg_external [label="external", fillcolor="#FFEBEE", color="#C62828"];
  }
}