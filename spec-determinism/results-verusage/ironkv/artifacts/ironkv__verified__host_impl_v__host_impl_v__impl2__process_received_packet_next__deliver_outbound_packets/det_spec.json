{
  "function": "deliver_outbound_packets",
  "det_check_template": "proof fn det_deliver_outbound_packets(self_: HostState, pre_netc: NetClient, packets: Vec<CPacket>, post1_netc: NetClient, r1: (rc: (bool, Ghost<Seq<NetEvent>>, Ghost<Seq<LSHTIo>>)), post2_netc: NetClient, r2: (rc: (bool, Ghost<Seq<NetEvent>>, Ghost<Seq<LSHTIo>>)))\n    requires (pre_netc.ok()), (outbound_packet_seq_is_valid(packets@)), (outbound_packet_seq_has_correct_srcs(packets@, pre_netc.my_end_point())),\n    ensures\n        ({\n            &&& (post1_netc.my_end_point() == pre_netc.my_end_point())\n            &&& (({\n                let (ok, Ghost(net_events), Ghost(ios)) = r1;\n                {\n                    &&& post1_netc.ok() <==> ok\n                    &&& ok ==> {\n                        &&& all_ios_are_sends(ios)\n                        &&& (forall |i: int| 0 <= i && i < net_events.len() ==> net_events[i] is Send)\n                        &&& ios == map_sent_packet_seq_to_ios(packets@)\n                        &&& abstractify_outbound_packets_to_seq_of_lsht_packets(packets@) ==\n                                extract_sent_packets_from_ios(ios)\n                        &&& abstractify_seq_of_cpackets_to_set_of_sht_packets(packets@) ==\n                                extract_packets_from_abstract_ios(ios)\n                        &&& no_invalid_sends(ios)\n                        &&& raw_io_consistent_with_spec_io(net_events, ios)\n                        &&& only_sent_marshalable_data(net_events)\n                        &&& post1_netc.history() == pre_netc.history() + net_events\n                    }\n                }\n            }))\n            &&& (post2_netc.my_end_point() == pre_netc.my_end_point())\n            &&& (({\n                let (ok, Ghost(net_events), Ghost(ios)) = r2;\n                {\n                    &&& post2_netc.ok() <==> ok\n                    &&& ok ==> {\n                        &&& all_ios_are_sends(ios)\n                        &&& (forall |i: int| 0 <= i && i < net_events.len() ==> net_events[i] is Send)\n                        &&& ios == map_sent_packet_seq_to_ios(packets@)\n                        &&& abstractify_outbound_packets_to_seq_of_lsht_packets(packets@) ==\n                                extract_sent_packets_from_ios(ios)\n                        &&& abstractify_seq_of_cpackets_to_set_of_sht_packets(packets@) ==\n                                extract_packets_from_abstract_ios(ios)\n                        &&& no_invalid_sends(ios)\n                        &&& raw_io_consistent_with_spec_io(net_events, ios)\n                        &&& only_sent_marshalable_data(net_events)\n                        &&& post2_netc.history() == pre_netc.history() + net_events\n                    }\n                }\n            }))\n        }) ==> det_deliver_outbound_packets_equal(r1, r2, post1_netc, post2_netc),\n{\n{ASSUMES}}",
