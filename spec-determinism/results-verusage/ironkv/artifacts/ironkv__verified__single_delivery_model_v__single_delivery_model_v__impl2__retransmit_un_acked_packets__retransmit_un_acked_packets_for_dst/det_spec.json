  "det_check_template": "proof fn det_retransmit_un_acked_packets_for_dst(self_: CSingleDelivery, src: EndPoint, dst: EndPoint, pre_packets: Vec<CPacket>, post1_packets: Vec<CPacket>, r1: (), post2_packets: Vec<CPacket>, r2: ())\n    requires (self_.valid()), (src.abstractable()), (outbound_packet_seq_is_valid(pre_packets@)), (outbound_packet_seq_has_correct_srcs(pre_packets@, src@)), (self_.send_state@.contains_key(dst@)), (Self::packets_are_valid_messages(pre_packets@)),\n    ensures\n        ({\n            &&& (post1_packets@.map_values(|p: CPacket| p@).to_set() ==\n            pre_packets@.map_values(|p: CPacket| p@).to_set() + self_@.un_acked_messages_for_dest(src@, dst@))\n            &&& (outbound_packet_seq_is_valid(post1_packets@))\n            &&& (outbound_packet_seq_has_correct_srcs(post1_packets@, src@))\n            &&& (Self::packets_are_valid_messages(post1_packets@))\n            &&& (post2_packets@.map_values(|p: CPacket| p@).to_set() ==\n            pre_packets@.map_values(|p: CPacket| p@).to_set() + self_@.un_acked_messages_for_dest(src@, dst@))\n            &&& (outbound_packet_seq_is_valid(post2_packets@))\n            &&& (outbound_packet_seq_has_correct_srcs(post2_packets@, src@))\n            &&& (Self::packets_are_valid_messages(post2_packets@))\n        }) ==> det_retransmit_un_acked_packets_for_dst_equal(r1, r2, post1_packets, post2_packets),\n{\n{ASSUMES}}",
