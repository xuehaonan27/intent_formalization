  "function": "receive_with_demarshal",
  "det_check_template": "proof fn det_receive_with_demarshal(pre_netc: NetClient, local_addr: EndPoint, post1_netc: NetClient, r1: (rc: (ReceiveResult, Ghost<NetEvent>)), post2_netc: NetClient, r2: (rc: (ReceiveResult, Ghost<NetEvent>)))\n    requires (pre_netc.ok()), (pre_netc.my_end_point() == local_addr@), (pre_netc.state() is Receiving), (local_addr.abstractable()),\n    ensures\n        ({\n            &&& (({let (rr, net_event) = r1;\n        &&& post1_netc.my_end_point() == pre_netc.my_end_point()\n        &&& post1_netc.ok() == !(rr is Fail)\n        &&& !(rr is Fail) ==> post1_netc.ok() && post1_netc.history() == pre_netc.history() + seq!( net_event@ )\n        &&& rr is Timeout ==> net_event@ is TimeoutReceive\n        &&& (rr is Packet ==> {\n            &&& net_event@ is Receive\n            &&& true // NetPacketIsAbstractable is true\n            &&& rr.arrow_Packet_cpacket().abstractable() // can parse u8s up to NetEvent.\n            &&& true  // EndPointIsValidPublicKey\n            &&& !(rr.arrow_Packet_cpacket()@.msg is InvalidMessage) ==> {\n                &&& rr.arrow_Packet_cpacket()@ == abstractify_net_packet_to_sht_packet(net_event@.arrow_Receive_r())\n                &&& rr.arrow_Packet_cpacket().msg@ == sht_demarshal_data(net_event@.arrow_Receive_r().msg)@\n            }\n            &&& rr.arrow_Packet_cpacket().dst@ == local_addr@\n        })\n}))\n            &&& (({let (rr, net_event) = r2;\n        &&& post2_netc.my_end_point() == pre_netc.my_end_point()\n        &&& post2_netc.ok() == !(rr is Fail)\n        &&& !(rr is Fail) ==> post2_netc.ok() && post2_netc.history() == pre_netc.history() + seq!( net_event@ )\n        &&& rr is Timeout ==> net_event@ is TimeoutReceive\n        &&& (rr is Packet ==> {\n            &&& net_event@ is Receive\n            &&& true // NetPacketIsAbstractable is true\n            &&& rr.arrow_Packet_cpacket().abstractable() // can parse u8s up to NetEvent.\n            &&& true  // EndPointIsValidPublicKey\n            &&& !(rr.arrow_Packet_cpacket()@.msg is InvalidMessage) ==> {\n                &&& rr.arrow_Packet_cpacket()@ == abstractify_net_packet_to_sht_packet(net_event@.arrow_Receive_r())\n                &&& rr.arrow_Packet_cpacket().msg@ == sht_demarshal_data(net_event@.arrow_Receive_r().msg)@\n            }\n            &&& rr.arrow_Packet_cpacket().dst@ == local_addr@\n        })\n}))\n        }) ==> det_receive_with_demarshal_equal(r1, r2, post1_netc, post2_netc),\n{\n{ASSUMES}}",
