{
  "function": "container_perms_update_subtree_set",
  "det_check_template": "proof fn det_container_perms_update_subtree_set(pre_perms: Tracked<Map<ContainerPtr, PointsTo<Container>>>, uppertree_seq: Ghost<Seq<ContainerPtr>>, new_container_ptr: ContainerPtr, post1_perms: Tracked<Map<ContainerPtr, PointsTo<Container>>>, r1: (), post2_perms: Tracked<Map<ContainerPtr, PointsTo<Container>>>, r2: ())\n    ensures\n        ({\n            &&& (pre_perms@.dom() =~= post1_perms@.dom())\n            &&& (forall|c_ptr: ContainerPtr|\n            #![trigger uppertree_seq@.contains(c_ptr)]\n            #![trigger post1_perms@.dom().contains(c_ptr)]\n            #![trigger post1_perms@[c_ptr]]\n            post1_perms@.dom().contains(c_ptr) && uppertree_seq@.contains(c_ptr) == false\n                ==> post1_perms@[c_ptr] =~= pre_perms@[c_ptr])\n            &&& (forall|c_ptr: ContainerPtr|\n         // #![trigger perms@[c_ptr].value().owning_container]\n\n            #![trigger post1_perms@.dom().contains(c_ptr)]\n            #![trigger post1_perms@[c_ptr]]\n            post1_perms@.dom().contains(c_ptr) ==> post1_perms@[c_ptr].is_init() =~= pre_perms@[c_ptr].is_init() && post1_perms@[c_ptr].addr() =~= pre_perms@[c_ptr].addr()\n                && post1_perms@[c_ptr].value().parent =~= pre_perms@[c_ptr].value().parent\n                && post1_perms@[c_ptr].value().parent_rev_ptr =~= pre_perms@[c_ptr].value().parent_rev_ptr && post1_perms@[c_ptr].value().children =~= pre_perms@[c_ptr].value().children && post1_perms@[c_ptr].value().depth =~= pre_perms@[c_ptr].value().depth && post1_perms@[c_ptr].value().uppertree_seq =~= pre_perms@[c_ptr].value().uppertree_seq\n            // &&\n            // perms@[c_ptr].value().subtree_set =~= pre_perms@[c_ptr].value().subtree_set\n             && post1_perms@[c_ptr].value().root_process =~= pre_perms@[c_ptr].value().root_process\n                && post1_perms@[c_ptr].value().owned_procs =~= pre_perms@[c_ptr].value().owned_procs\n                && post1_perms@[c_ptr].value().owned_endpoints =~= pre_perms@[c_ptr].value().owned_endpoints && post1_perms@[c_ptr].value().owned_threads =~= pre_perms@[c_ptr].value().owned_threads && post1_perms@[c_ptr].value().quota =~= pre_perms@[c_ptr].value().quota\n            // &&\n            // perms@[c_ptr].value().mem_used =~= pre_perms@[c_ptr].value().mem_used\n             && post1_perms@[c_ptr].value().owned_cpus =~= pre_perms@[c_ptr].value().owned_cpus\n                && post1_perms@[c_ptr].value().scheduler =~= pre_perms@[c_ptr].value().scheduler\n                && post1_perms@[c_ptr].value().can_have_children =~= pre_perms@[c_ptr].value().can_have_children)\n            &&& (forall|c_ptr: ProcPtr|\n            #![trigger uppertree_seq@.contains(c_ptr)]\n            #![trigger post1_perms@[c_ptr].value().subtree_set]\n            #![trigger pre_perms@[c_ptr].value().subtree_set]\n            uppertree_seq@.contains(c_ptr) ==> post1_perms@[c_ptr].value().subtree_set@ =~= pre_perms@[c_ptr].value().subtree_set@.insert(new_container_ptr))\n            &&& (post1_perms@[new_container_ptr].value().subtree_set =~= pre_perms@[new_container_ptr].value().subtree_set)\n            &&& (pre_perms@.dom() =~= post2_perms@.dom())\n            &&& (forall|c_ptr: ContainerPtr|\n            #![trigger uppertree_seq@.contains(c_ptr)]\n            #![trigger post2_perms@.dom().contains(c_ptr)]\n            #![trigger post2_perms@[c_ptr]]\n            post2_perms@.dom().contains(c_ptr) && uppertree_seq@.contains(c_ptr) == false\n                ==> post2_perms@[c_ptr] =~= pre_perms@[c_ptr])\n            &&& (forall|c_ptr: ContainerPtr|\n         // #![trigger perms@[c_ptr].value().owning_container]\n\n            #![trigger post2_perms@.dom().contains(c_ptr)]\n            #![trigger post2_perms@[c_ptr]]\n            post2_perms@.dom().contains(c_ptr) ==> post2_perms@[c_ptr].is_init() =~= pre_perms@[c_ptr].is_init() && post2_perms@[c_ptr].addr() =~= pre_perms@[c_ptr].addr()\n                && post2_perms@[c_ptr].value().parent =~= pre_perms@[c_ptr].value().parent\n                && post2_perms@[c_ptr].value().parent_rev_ptr =~= pre_perms@[c_ptr].value().parent_rev_ptr && post2_perms@[c_ptr].value().children =~= pre_perms@[c_ptr].value().children && post2_perms@[c_ptr].value().depth =~= pre_perms@[c_ptr].value().depth && post2_perms@[c_ptr].value().uppertree_seq =~= pre_perms@[c_ptr].value().uppertree_seq\n            // &&\n            // perms@[c_ptr].value().subtree_set =~= pre_perms@[c_ptr].value().subtree_set\n             && post2_perms@[c_ptr].value().root_process =~= pre_perms@[c_ptr].value().root_process\n                && post2_perms@[c_ptr].value().owned_procs =~= pre_perms@[c_ptr].value().owned_procs\n                && post2_perms@[c_ptr].value().owned_endpoints =~= pre_perms@[c_ptr].value().owned_endpoints && post2_perms@[c_ptr].value().owned_threads =~= pre_perms@[c_ptr].value().owned_threads && post2_perms@[c_ptr].value().quota =~= pre_perms@[c_ptr].value().quota\n            // &&\n            // perms@[c_ptr].value().mem_used =~= pre_perms@[c_ptr].value().mem_used\n             && post2_perms@[c_ptr].value().owned_cpus =~= pre_perms@[c_ptr].value().owned_cpus\n                && post2_perms@[c_ptr].value().scheduler =~= pre_perms@[c_ptr].value().scheduler\n                && post2_perms@[c_ptr].value().can_have_children =~= pre_perms@[c_ptr].value().can_have_children)\n            &&& (forall|c_ptr: ProcPtr|\n            #![trigger uppertree_seq@.contains(c_ptr)]\n            #![trigger post2_perms@[c_ptr].value().subtree_set]\n            #![trigger pre_perms@[c_ptr].value().subtree_set]\n            uppertree_seq@.contains(c_ptr) ==> post2_perms@[c_ptr].value().subtree_set@ =~= pre_perms@[c_ptr].value().subtree_set@.insert(new_container_ptr))\n            &&& (post2_perms@[new_container_ptr].value().subtree_set =~= pre_perms@[new_container_ptr].value().subtree_set)\n        }) ==> det_container_perms_update_subtree_set_equal(r1, r2, post1_perms, post2_perms),\n{\n{ASSUMES}}",
