         post1_proc_perm@.value().children@.contains(v) ==> \n                pre_proc_perm@.value().children.get_node_ref(v) == \n                    post1_proc_perm@.value().children.get_node_ref(v))\n            &&& (post1_proc_perm@.value().children.unique())\n            &&& (post2_proc_perm@.is_init())\n            &&& (post2_proc_perm@.addr() == proc_ptr)\n            &&& (post2_proc_perm@.value().owning_container =~= pre_proc_perm@.value().owning_container)\n            &&& (post2_proc_perm@.value().rev_ptr =~= pre_proc_perm@.value().rev_ptr)\n            &&& (post2_proc_perm@.value().pcid =~= pre_proc_perm@.value().pcid)\n            &&& (post2_proc_perm@.value().ioid =~= pre_proc_perm@.value().ioid)\n            &&& (post2_proc_perm@.value().owned_threads =~= pre_proc_perm@.value().owned_threads)\n            &&& (post2_proc_perm@.value().parent =~= pre_proc_perm@.value().parent)\n            &&& (post2_proc_perm@.value().parent_rev_ptr =~= pre_proc_perm@.value().parent_rev_ptr)\n            &&& (post2_proc_perm@.value().uppertree_seq =~= pre_proc_perm@.value().uppertree_seq)\n            &&& (post2_proc_perm@.value().subtree_set =~= pre_proc_perm@.value().subtree_set)\n            &&& (post2_proc_perm@.value().depth =~= pre_proc_perm@.value().depth)\n            &&& (post2_proc_perm@.value().dmd_paging_mode =~= pre_proc_perm@.value().dmd_paging_mode)\n            &&& (post2_proc_perm@.value().children.wf())\n            &&& (post2_proc_perm@.value().children@ =~= pre_proc_perm@.value().children@.remove_value(child_proc_ptr@))\n            &&& (post2_proc_perm@.value().children.len() == pre_proc_perm@.value().children.len() - 1)\n            &&& (forall|v:ProcPtr|\n            #![auto]\n            post2_proc_perm@.value().children@.contains(v) ==> \n                pre_proc_perm@.value().children.get_node_ref(v) == \n                    post2_proc_perm@.value().children.get_node_ref(v))\n            &&& (post2_proc_perm@.value().children.unique())\n      