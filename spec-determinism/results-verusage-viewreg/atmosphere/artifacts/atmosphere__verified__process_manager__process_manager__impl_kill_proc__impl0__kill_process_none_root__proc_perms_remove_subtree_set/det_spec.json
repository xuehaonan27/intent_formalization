{
  "function": "proc_perms_remove_subtree_set",
  "det_check_template": "proof fn det_proc_perms_remove_subtree_set(pre_perms: Tracked<Map<ProcPtr, PointsTo<Process>>>, uppertree_seq: Ghost<Seq<ProcPtr>>, proc_ptr: ProcPtr, post1_perms: Tracked<Map<ProcPtr, PointsTo<Process>>>, r1: (), post2_perms: Tracked<Map<ProcPtr, PointsTo<Process>>>, r2: ())\n    ensures\n        ({\n            &&& (pre_perms@.dom() =~= post1_perms@.dom())\n            &&& (forall|p_ptr: ProcPtr|\n            #![trigger uppertree_seq@.contains(p_ptr)]\n            #![trigger post1_perms@.dom().contains(p_ptr)]\n            #![trigger post1_perms@[p_ptr]]\n            post1_perms@.dom().contains(p_ptr) && uppertree_seq@.contains(p_ptr) == false\n                ==> post1_perms@[p_ptr] =~= pre_perms@[p_ptr])\n            &&& (forall|p_ptr: ProcPtr|\n            #![trigger post1_perms@.dom().contains(p_ptr)]\n            #![trigger post1_perms@[p_ptr]]\n            post1_perms@.dom().contains(p_ptr) \n            ==> post1_perms@[p_ptr].is_init() =~= pre_perms@[p_ptr].is_init() && post1_perms@[p_ptr].addr() =~= pre_perms@[p_ptr].addr()\n                && post1_perms@[p_ptr].value().owning_container =~= pre_perms@[p_ptr].value().owning_container && post1_perms@[p_ptr].value().rev_ptr =~= pre_perms@[p_ptr].value().rev_ptr && post1_perms@[p_ptr].value().pcid =~= pre_perms@[p_ptr].value().pcid && post1_perms@[p_ptr].value().ioid =~= pre_perms@[p_ptr].value().ioid\n                && post1_perms@[p_ptr].value().owned_threads =~= pre_perms@[p_ptr].value().owned_threads\n                && post1_perms@[p_ptr].value().parent =~= pre_perms@[p_ptr].value().parent\n                && post1_perms@[p_ptr].value().parent_rev_ptr =~= pre_perms@[p_ptr].value().parent_rev_ptr && post1_perms@[p_ptr].value().children =~= pre_perms@[p_ptr].value().children && post1_perms@[p_ptr].value().uppertree_seq =~= pre_perms@[p_ptr].value().uppertree_seq && post1_perms@[p_ptr].value().depth =~= pre_perms@[p_ptr].value().depth && post1_perms@[p_ptr].value().dmd_paging_mode =~= pre_perms@[p_ptr].value().dmd_paging_mode)\n            &&& (forall|p_ptr: ProcPtr|\n            #![trigger uppertree_seq@.contains(p_ptr)]\n            #![trigger post1_perms@[p_ptr].value()]\n            #![trigger post1_perms@[p_ptr].value().subtree_set]\n            #![trigger pre_perms@[p_ptr].value().subtree_set]\n            uppertree_seq@.contains(p_ptr) ==> post1_perms@[p_ptr].value().subtree_set@ =~= \n            pre_perms@[p_ptr].value().subtree_set@.remove(proc_ptr))\n            &&& (pre_perms@.dom() =~= post2_perms@.dom())\n            &&& (forall|p_ptr: ProcPtr|\n            #![trigger uppertree_seq@.contains(p_ptr)]\n            #![trigger post2_perms@.dom().contains(p_ptr)]\n            #![trigger post2_perms@[p_ptr]]\n            post2_perms@.dom().contains(p_ptr) && uppertree_seq@.contains(p_ptr) == false\n                ==> post2_perms@[p_ptr] =~= pre_perms@[p_ptr])\n            &&& (forall|p_ptr: ProcPtr|\n            #![trigger post2_perms@.dom().contains(p_ptr)]\n            #![trigger post2_perms@[p_ptr]]\n            post2_perms@.dom().contains(p_ptr) \n            ==> post2_perms@[p_ptr].is_init() =~= pre_perms@[p_ptr].is_init() && post2_perms@[p_ptr].addr() =~= pre_perms@[p_ptr].addr()\n                && post2_perms@[p_ptr].value().owning_container =~= pre_perms@[p_ptr].value().owning_container && post2_perms@[p_ptr].value().rev_ptr =~= pre_perms@[p_ptr].value().rev_ptr && post2_perms@[p_ptr].value().pcid =~= pre_perms@[p_ptr].value().pcid && post2_perms@[p_ptr].value().ioid =~= pre_perms@[p_ptr].value().ioid\n                && post2_perms@[p_ptr].value().owned_threads =~= pre_perms@[p_ptr].value().owned_threads\n                && post2_perms@[p_ptr].value().parent =~= pre_perms@[p_ptr].value().parent\n                && post2_perms@[p_ptr].value().parent_rev_ptr =~= pre_perms@[p_ptr].value().parent_rev_ptr && post2_perms@[p_ptr].value().children =~= pre_perms@[p_ptr].value().children && post2_perms@[p_ptr].value().uppertree_seq =~= pre_perms@[p_ptr].value().uppertree_seq && post2_perms@[p_ptr].value().depth =~= pre_perms@[p_ptr].value().depth && post2_perms@[p_ptr].value().dmd_paging_mode =~= pre_perms@[p_ptr].value().dmd_paging_mode)\n            &&& (forall|p_ptr: ProcPtr|\n            #![trigger uppertree_seq@.contains(p_ptr)]\n            #![trigger post2_perms@[p_ptr].value()]\n            #![trigger post2_perms@[p_ptr].value().subtree_set]\n            #![trigger pre_perms@[p_ptr].value().subtree_set]\n            uppertree_seq@.contains(p_ptr) ==> post2_perms@[p_ptr].value().subtree_set@ =~= \n            pre_perms@[p_ptr].value().subtree_set@.remove(proc_ptr))\n        }) ==> det_proc_perms_remove_subtree_set_equal(r1, r2, post1_perms, post2_perms),\n{\n{ASSUMES}}",
