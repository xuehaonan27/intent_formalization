  "det_check_template": "proof fn det_endpoint_remove_ref(endpoint_ptr: EndpointPtr, pre_endpoint_perm: Tracked<PointsTo<Endpoint>>, thread_ptr: ThreadPtr, endpoint_idx: EndpointIdx, post1_endpoint_perm: Tracked<PointsTo<Endpoint>>, r1: (), post2_endpoint_perm: Tracked<PointsTo<Endpoint>>, r2: ())\n    requires (pre_endpoint_perm@.is_init()), (pre_endpoint_perm@.addr() == endpoint_ptr), (pre_endpoint_perm@.value().rf_counter != 0), (pre_endpoint_perm@.value().get_owning_threads().contains((thread_ptr, endpoint_idx))),\n    ensures\n        ({\n            &&& (post1_endpoint_perm@.is_init())\n            &&& (post1_endpoint_perm@.addr() == endpoint_ptr)\n            &&& (post1_endpoint_perm@.value().queue == pre_endpoint_perm@.value().queue)\n            &&& (post1_endpoint_perm@.value().queue_state == pre_endpoint_perm@.value().queue_state)\n            &&& (post1_endpoint_perm@.value().owning_container == pre_endpoint_perm@.value().owning_container)\n            &&& (post1_endpoint_perm@.value().rf_counter == pre_endpoint_perm@.value().rf_counter - 1)\n            &&& (post1_endpoint_perm@.value().get_owning_threads() == pre_endpoint_perm@.value().get_owning_threads().remove((thread_ptr, endpoint_idx)))\n            &&& (post2_endpoint_perm@.is_init())\n            &&& (post2_endpoint_perm@.addr() == endpoint_ptr)\n            &&& (post2_endpoint_perm@.value().queue == pre_endpoint_perm@.value().queue)\n            &&& (post2_endpoint_perm@.value().queue_state == pre_endpoint_perm@.value().queue_state)\n            &&& (post2_endpoint_perm@.value().owning_container == pre_endpoint_perm@.value().owning_container)\n            &&& (post2_endpoint_perm@.value().rf_counter == pre_endpoint_perm@.value().rf_counter - 1)\n            &&& (post2_endpoint_perm@.value().get_owning_threads() == pre_endpoint_perm@.value().get_owning_threads().remove((thread_ptr, endpoint_idx)))\n        }) ==> det_endpoint_remove_ref_equal(r1, r2, post1_endpoint_perm, post2_endpoint_perm),\n{