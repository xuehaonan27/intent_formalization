{
  "function": "host_model_next_receive_message",
  "det_check_template": "proof fn det_host_model_next_receive_message(pre_self_: HostState, post1_self_: HostState, r1: Vec<CPacket>, post2_self_: HostState, r2: Vec<CPacket>)\n    requires (({\n            let old_self = *pre_self_;\n            match old_self.received_packet {\n                Some(cpacket) => {\n                    &&& pre_self_.sd.valid()\n                    &&& pre_self_.host_state_common_preconditions()\n                    &&& match cpacket.msg {\n                          CSingleMessage::Message{m: m, ..} =>\n                              match m {\n                                  CMessage::GetRequest{..} => old_self.next_get_request_preconditions(),\n                                  CMessage::SetRequest{..} => old_self.next_set_request_preconditions(),\n                                  CMessage::Delegate{..} => old_self.next_delegate_preconditions(),\n                                  CMessage::Shard{..} => old_self.next_shard_preconditions(),\n                                  _ => true,\n                              }\n                          _ => false,\n                      }\n                },\n                None => false,\n            }\n        })),\n    ensures\n        ({\n            &&& (match pre_self_.received_packet {\n                Some(cpacket) => {\n                    &&& cpacket_seq_is_abstractable(r1@)\n                    &&& post1_self_.host_state_common_postconditions(pre_self_, (pre_self_).received_packet.unwrap(),\n                                                            r1@)\n                    &&& {\n                         ||| process_message(pre_self_@, post1_self_@,\n                               abstractify_seq_of_cpackets_to_set_of_sht_packets(r1@))\n                         ||| HostState::host_ignoring_unparseable(pre_self_@, post1_self_@,\n                               abstractify_seq_of_cpackets_to_set_of_sht_packets(r1@))\n                        }\n                },\n                None => false,\n            })\n            &&& (match pre_self_.received_packet {\n                Some(cpacket) => {\n                    &&& cpacket_seq_is_abstractable(r2@)\n                    &&& post2_self_.host_state_common_postconditions(pre_self_, (pre_self_).received_packet.unwrap(),\n                                                            r2@)\n                    &&& {\n                         ||| process_message(pre_self_@, post2_self_@,\n                               abstractify_seq_of_cpackets_to_set_of_sht_packets(r2@))\n                         ||| HostState::host_ignoring_unparseable(pre_self_@, post2_self_@,\n                               abstractify_seq_of_cpackets_to_set_of_sht_packets(r2@))\n                        }\n                },\n                None => false,\n            })\n        }) ==> det_host_model_next_receive_message_equal(r1, r2, post1_self_, post2_self_),\n{\n{ASSUMES}}",
